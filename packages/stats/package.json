{
  "name": "sonicjs-stats",
  "version": "0.1.0",
  "private": true,
  "description": "SonicJS telemetry stats collector",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'Worker build is handled by wrangler during deployment'",
    "deploy": "wrangler deploy",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "db:reset:local": "bash scripts/setup-local.sh",
    "setup:db": "npm run db:reset:local",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sonicjs-cms/core": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^20.19.1",
    "hono": "^4.12.26",
    "typescript": "^5.8.3",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
